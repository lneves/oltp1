[mysqld]

# Basic Settings
user = mysql
port = 3306
datadir = /var/lib/mysql
socket = /var/run/mysqld/mysqld.sock
pid-file = /var/run/mysqld/mysqld.pid
tmpdir = /tmp

# InnoDB Settings (OLTP-focused)
innodb_buffer_pool_size = 24G           # ~75% of RAM
innodb_buffer_pool_instances = 8        # for concurrency
innodb_log_file_size = 1G               # size of redo logs
innodb_log_files_in_group = 2
innodb_log_buffer_size = 256M
innodb_flush_log_at_trx_commit = 1      # full durability
innodb_flush_method = O_DIRECT
innodb_file_per_table = 1
innodb_io_capacity = 1000               # tuned for SSD
innodb_io_capacity_max = 2000
innodb_read_io_threads = 8
innodb_write_io_threads = 8
innodb_thread_concurrency = 16
innodb_flush_neighbors = 0              # SSD optimization

# Binary Logging (for replication or PITR)
log_bin = /mnt/binlog/mysql-bin         # <== place on second SSD
binlog_format = ROW                     # safest for OLTP
binlog_row_image = minimal              # reduces binlog size
sync_binlog = 1                         # sync at each transaction
expire_logs_days = 7
max_binlog_size = 512M

# Query Cache (usually disabled for InnoDB)
query_cache_type = 0
query_cache_size = 0

# Slow Query Log
slow_query_log = 1
slow_query_log_file = /var/log/mysql/slow.log
long_query_time = 1
log_queries_not_using_indexes = 1

# Connections and Buffers
max_connections = 500
max_allowed_packet = 64M
table_open_cache = 4096
open_files_limit = 65535
sort_buffer_size = 4M
join_buffer_size = 4M
read_buffer_size = 2M
read_rnd_buffer_size = 2M
thread_cache_size = 100

# Logging
log_error = /var/log/mysql/error.log
general_log = 0

# Character Set
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

# Performance Schema
performance_schema = ON

# Security (optional, remove if not needed)
skip-symbolic-links
